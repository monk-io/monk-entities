# Azure Service Bus Test Environment Variables
# Copy this file to .env and fill in your values

# Azure Subscription ID
AZURE_SUBSCRIPTION_ID=your-subscription-id

# Azure Resource Group Name
AZURE_RESOURCE_GROUP=your-resource-group

# Service Bus Namespace Name (optional, defaults to monkec-test-sb)
AZURE_SERVICEBUS_NAMESPACE=your-servicebus-namespace

# Azure credentials are typically injected by the runtime
# If running locally, you may need to set these:
# AZURE_CLIENT_ID=your-client-id
# AZURE_CLIENT_SECRET=your-client-secret
# AZURE_TENANT_ID=your-tenant-id
