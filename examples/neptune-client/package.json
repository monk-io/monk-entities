{
  "name": "neptune-client",
  "version": "1.0.0",
  "description": "TypeScript Neptune client demonstrating graph database operations with AWS Neptune",
  "main": "dist/client.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/client.js",
    "dev": "ts-node src/client.ts",
    "clean": "rm -rf dist",
    "test": "npm run build && npm start"
  },
  "keywords": [
    "aws",
