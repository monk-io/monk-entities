# Neptune Configuration
NEPTUNE_HOST=neptune-example-cluster.cluster-xxxxx.us-east-1.neptune.amazonaws.com
NEPTUNE_PORT=8182
NEPTUNE_USE_SSL=true
NEPTUNE_TIMEOUT=30000

# Alternative variable names (also supported)
# DB_HOST=neptune-example-cluster.cluster-xxxxx.us-east-1.neptune.amazonaws.com
# DB_PORT=8182
# USE_SSL=true
# DB_TIMEOUT=30000

# Application Settings
OPERATION_INTERVAL_MS=10000
