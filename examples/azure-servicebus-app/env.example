# ========================================
# Azure Service Bus App Configuration
# ========================================

# Connection string from Service Bus namespace
# Automatically provided by MonkEC via secret reference
SERVICEBUS_CONNECTION_STRING=Endpoint=sb://your-namespace.servicebus.windows.net/;SharedAccessKeyName=RootManageSharedAccessKey;SharedAccessKey=your-key

# Topic and queue names (must match the YAML template)
TOPIC_NAME=order-events
QUEUE_NAME=commands

# Client operational settings
OPERATION_INTERVAL_MS=5000
MAX_OPERATIONS=20
