REPO rds-client

LOAD rds-client.yaml

ENV dev staging prod

# Default entrypoint targets AWS production (MySQL) stack.
ENTRY rds-client/prod
ENTRY prod:rds-client/prod
ENTRY staging:rds-client/staging
ENTRY dev:rds-client/dev

# Container image build for the Node.js client runnable(s)
IMAGE rds-client:latest rds-client/rds-client-base,rds-client/mysql-client-prod,rds-client/postgres-client-prod . Dockerfile
