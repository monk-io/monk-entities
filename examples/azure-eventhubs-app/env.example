# ========================================
# Azure Event Hubs App Configuration
# ========================================

# Connection string from Event Hubs namespace
# Automatically provided by MonkEC via secret reference
EVENTHUBS_CONNECTION_STRING=Endpoint=sb://your-namespace.servicebus.windows.net/;SharedAccessKeyName=RootManageSharedAccessKey;SharedAccessKey=your-key

# Event Hub names (must match the YAML template)
TELEMETRY_HUB_NAME=telemetry
ALERTS_HUB_NAME=alerts

# Consumer group for reading events
CONSUMER_GROUP=realtime-dashboard

# Client operational settings
OPERATION_INTERVAL_MS=3000
MAX_OPERATIONS=30
